# PostgreSQL connection, used by both the Prisma CLI (migrate/studio) and the
# running server. Start a local dev database with, e.g.:
#   docker run -d -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16-alpine
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app"

# HTTP port for the Fastify server
PORT=4000
